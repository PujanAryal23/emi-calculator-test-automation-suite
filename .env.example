BASE_URL=https://emicalculator.net/

# Single browser (back-compat) or comma-separated list. BROWSERS wins.
# Valid values: chromium, firefox, webkit
BROWSERS=chromium

# Default is headed locally so you can watch tests run. CI overrides to true.
HEADLESS=false

SLOW_MO_MS=0
DEFAULT_TIMEOUT_MS=15000
DOWNLOAD_DIR=./downloads
